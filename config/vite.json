{
  "all": {
    "packageManager": "pnpm",
    "sourceCodeDir": "app/javascript",
    "watchAdditionalPaths": [
      "app/views/**/*.erb",
      "app/helpers/**/*.rb",
      "app/components/**/*",
      "config/locales/**/*.yml"
    ]
  },
  "development": {
    "autoBuild": true,
    "publicOutputDir": "vite-dev",
    "port": 3036
  },
  "test": {
    "autoBuild": true,
    "publicOutputDir": "vite-test",
    "port": 3037
  }
}
